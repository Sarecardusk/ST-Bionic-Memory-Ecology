      "maxResponseBytes": 67108864
    },
    "vector.apply": {
      "name": "vector.apply",
      "version": "1.0.0",
      "title": "BME vector apply",
      "description": "Applies BME vector upserts and links through the DOA generic trivium wrapper.",
      "riskLevel": "high",
      "permissionTarget": { "kind": "transaction" },
      "requiredResources": [{ "resource": "trivium.private" }],
      "idempotency": "required",
      "timeoutMs": 120000,
      "maxRequestBytes": 67108864,
      "maxResponseBytes": 67108864
    }
